{
  "name": "setup-gcc-toolchain",
  "version": "1.0.0",
  "description": "GitHub Action to download and configure GCC cross-compilation toolchains",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --noEmit && esbuild src/index.ts --bundle --platform=node --target=node24 --format=esm --banner:js=\"import{createRequire as __cr}from'module';const require=__cr(import.meta.url);\" --outfile=dist/index.js --minify",
    "build:dev": "esbuild src/index.ts --bundle --platform=node --target=node24 --format=esm --banner:js=\"import{createRequire as __cr}from'module';const require=__cr(import.meta.url);\" --outfile=dist/index.js --sourcemap",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "validate": "node scripts/validate-toolchains.mjs --no-network",
    "validate:full": "node scripts/validate-toolchains.mjs",
    "check-versions": "node scripts/check-new-versions.mjs"
  },
  "keywords": [
    "gcc",
    "toolchain",
    "cross-compilation",
    "arm-none-eabi",
    "aarch64",
    "riscv",
    "avr",
    "embedded",
    "github-actions"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@actions/cache": "^6.1.0",
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/tool-cache": "^4.0.0",
    "js-yaml": "^5.2.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.0.1",
    "esbuild": "^0.28.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [ ".ts" ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.ts$": [ "ts-jest", { "useESM": true } ]
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  }
}
