{
  "name": "setup-gcc-toolchain",
  "version": "1.0.0",
  "description": "GitHub Action to download and configure GCC cross-compilation toolchains",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && ncc build src/index.ts -o dist --minify",
    "build:dev": "ncc build src/index.ts -o dist --source-map",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "validate": "node scripts/validate-toolchains.mjs --no-network",
    "validate:full": "node scripts/validate-toolchains.mjs"
  },
  "keywords": [
    "gcc",
    "toolchain",
    "cross-compilation",
    "arm-none-eabi",
    "aarch64",
    "riscv",
    "avr",
    "embedded",
    "github-actions"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@actions/cache": "^3.2.4",
    "@actions/core": "^1.10.1",
    "@actions/exec": "^1.1.1",
    "@actions/tool-cache": "^2.0.1",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@vercel/ncc": "^0.38.1",
    "jest": "^29.7.0",
    "@jest/globals": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  }
}
