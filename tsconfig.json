{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [ "ES2022" ],
    "outDir": "./lib",
    "rootDir": ".",
    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": [ "node" ]
  },
  "include": [ "src/**/*", "shared/**/*" ],
  "exclude": [ "node_modules", "dist", "__tests__" ]
}
